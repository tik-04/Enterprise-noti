{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/enterprise-noti/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/enterprise-noti/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/enterprise-noti",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json",
        "assets": [],
        "watchAssets": false
      }
    },
    "email-worker": {
      "type": "application",
      "root": "apps/email-worker",
      "entryFile": "main",
      "sourceRoot": "apps/email-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/email-worker/tsconfig.app.json"
      }
    },
    "enterprise-noti": {
      "type": "application",
      "root": "apps/enterprise-noti",
      "entryFile": "main",
      "sourceRoot": "apps/enterprise-noti/src",
      "compilerOptions": {
        "tsConfigPath": "apps/enterprise-noti/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "sms-worker": {
      "type": "application",
      "root": "apps/sms-worker",
      "entryFile": "main",
      "sourceRoot": "apps/sms-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sms-worker/tsconfig.app.json"
      }
    }
  }
}